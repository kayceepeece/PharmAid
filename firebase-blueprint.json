{
  "entities": {
    "Note": {
      "title": "Note",
      "description": "User notes with pharmacy concepts",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["userId", "title", "content", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/notes/{noteId}": {
      "schema": { "$ref": "#/entities/Note" },
      "description": "Collection of notes"
    }
  }
}
